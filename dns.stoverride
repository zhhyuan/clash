name: dns
desc: dns




 dns:
   enable: true
   listen: 0.0.0.0:53
   default-nameserver:
    - 119.29.29.29
    - 223.5.5.5
 nameserver:
 - https://doh.pub/dns-query
 - https://dns.alidns.com/dns-query
 - tls://b.iqiq.io:853
 fallback:
 - https://1.1.1.1/dns-query
 - https://dns.google/dns-query
 - 8.8.8.8
 - https://a.passcloud.xyz/cdn
 fallback-filter:
 geoip: true
 geoip-code: CN
 ipcidr:
 - 240.0.0.0/4
